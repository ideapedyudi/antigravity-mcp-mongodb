# MongoDB Connection String
# Example: mongodb://localhost:27017
# Example: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb://localhost:27017

# MCP Transport Mode: "stdio" (default) or "http" (backend service)
# Use "stdio" for direct file execution via Antigravity
# Use "http" to run as a persistent backend service
MCP_MODE=stdio

# Port for HTTP mode (only active if MCP_MODE=http)
PORT=3000
