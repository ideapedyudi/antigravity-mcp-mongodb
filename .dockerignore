# Node.js dependencies — no need to copy to image (will be reinstalled by npm ci)
node_modules/

# TypeScript build output folder — will be rebuilt inside Docker
dist/

# Environment files — NEVER include these in the Docker image!
.env

# Log files
*.log
npm-debug.log*

# OS files
.DS_Store
Thumbs.db

# Editor files
.vscode/
.idea/

# Git
.git/
.gitignore
